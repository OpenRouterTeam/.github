{
  "name": "openrouter-stats-cards",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "fetch": "node scripts/fetch-stats.mjs",
    "render": "npm run fetch && npm run render:models && npm run render:providers && npm run render:tokens",
    "render:models": "remotion render models ../profile/assets/stat-models.gif --codec=gif --number-of-gif-loops=0 --props=out/props-models.json",
    "render:providers": "remotion render providers ../profile/assets/stat-providers.gif --codec=gif --number-of-gif-loops=0 --props=out/props-providers.json",
    "render:tokens": "remotion render tokens ../profile/assets/stat-tokens.gif --codec=gif --number-of-gif-loops=0 --props=out/props-tokens.json"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.229",
    "@remotion/google-fonts": "^4.0.486",
    "@remotion/tailwind-v4": "^4.0.229",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.229",
    "tailwindcss": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
